        for name, g in [("Лево", 3), ("Центр", 1), ("Право", 5)]:
            btn = jclass("android.widget.TextView")(self.context); btn.setText(name); btn.setGravity(17); btn.setPadding(0, AndroidUtilities.dp(8), 0, AndroidUtilities.dp(8)); is_act = (self.plugin.get_setting(key, default) == g); btn.setTextColor(jint(Theme.getColor(Theme.key_featuredStickers_buttonText if is_act else Theme.key_windowBackgroundWhiteBlueHeader))); btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AndroidUtilities.dp(8), jint(Theme.getColor(Theme.key_featuredStickers_addButton) if is_act else Color.TRANSPARENT), jint(Color.TRANSPARENT))); btn.setOnClickListener(OnClickProxy(lambda v, g_val=g: on_align_click(v, g_val))); buttons_refs.append((btn, g)); btn_row.addView(btn, LayoutHelper.createLinear(0, -2, 1.0, 2, 0, 2, 0))
        row.addView(btn_row, LayoutHelper.createLinear(-1, -2)); self.settings_container.addView(row)

    def _style_seekbar(self, sb):
        CSL = jclass("android.content.res.ColorStateList"); accent, inactive = jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader)), jint(Theme.getColor(Theme.key_switchTrack))
        try: sb.setProgressTintList(CSL.valueOf(accent)); sb.setThumbTintList(CSL.valueOf(accent)); sb.setProgressBackgroundTintList(CSL.valueOf(inactive))
        except: pass

    def _create_seek_touch_proxy(self):
        class SeekTouchProxy(dynamic_proxy(jclass("android.view.View$OnTouchListener"))):
            def onTouch(self, v, event):
                try:
                    action = event.getActionMasked(); p = v.getParent()
                    if action == 0:
                        while p: p.requestDisallowInterceptTouchEvent(True); p = p.getParent()
                    elif action == 1 or action == 3:
                        while p: p.requestDisallowInterceptTouchEvent(False); p = p.getParent()
                except: pass
                return False
        return SeekTouchProxy()

    def _add_slider(self, text, key, min_val, max_val, default):
        ll = LinearLayout(self.context); ll.setOrientation(1); ll.setPadding(AndroidUtilities.dp(23), AndroidUtilities.dp(10), AndroidUtilities.dp(23), AndroidUtilities.dp(10)); tv = jclass("android.widget.TextView")(self.context); val = int(self.plugin.get_setting(key, default)); tv.setText(f"{text}: {val}"); tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))); ll.addView(tv); sb = SeekBar(self.context); self._style_seekbar(sb); sb.setMax(max_val - min_val); sb.setProgress(val - min_val); sb.setOnTouchListener(self._create_seek_touch_proxy())
