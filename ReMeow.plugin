                    p = float(a.getAnimatedValue())
                    self.d.current_rect.left = self.s.left + (self.e.left - self.s.left) * p
                    self.d.current_rect.top = self.s.top + (self.e.top - self.s.top) * p
                    self.d.current_rect.right = self.s.right + (self.e.right - self.s.right) * p
                    self.d.current_rect.bottom = self.s.bottom + (self.e.bottom - self.s.bottom) * p
                    (self.d.view.invalidate() if self.d.view else None)
            self.animator = ValueAnimator.ofFloat(jarray(jfloat)([0.0, 1.0]))
            self.animator.setDuration(250); self.animator.setInterpolator(jclass("org.telegram.ui.Components.CubicBezierInterpolator").EASE_OUT_QUINT)
            self.animator.addUpdateListener(AnimUpdate(self, RectF(self.current_rect), self.target_rect)); self.animator.start()

    def onDraw(self, canvas, callback):
        if not self.current_rect.isEmpty(): rad = self.target_radius; canvas.drawRoundRect(self.current_rect, rad, rad, self.fill_paint); canvas.drawRoundRect(self.current_rect, rad, rad, self.stroke_paint)
