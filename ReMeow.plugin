        sb.setOnSeekBarChangeListener(SimpleSeekListener(lambda prog: (v := min_val + (max_val - min_val) * (prog / 100.0), tv.setText(f"{text}: {v:.2f}"), self.plugin.set_setting(key, v), self._update_preview_from_settings(animate=False)))); ll.addView(sb, LayoutHelper.createLinear(-1, -2, 0, 10, 0, 0)); self.settings_container.addView(ll)
    def _add_input(self, text, key, default):
