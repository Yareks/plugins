    def _add_icon_selector_btn(self):
        btn = jclass("android.widget.TextView")(self.context); btn.setText("Выбрать иконку (Поиск)"); btn.setGravity(17); btn.setTextColor(jint(Theme.getColor(Theme.key_featuredStickers_buttonText))); btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AndroidUtilities.dp(8), jint(Theme.getColor(Theme.key_featuredStickers_addButton)), jint(Color.TRANSPARENT))); btn.setPadding(0, AndroidUtilities.dp(12), 0, AndroidUtilities.dp(12))
        btn.setOnClickListener(OnClickProxy(lambda v: self._show_icons_bottom_sheet())); self.settings_container.addView(btn, LayoutHelper.createLinear(-1, -2, 23, 16, 23, 0))

    def _show_icons_bottom_sheet(self):
        try:
            if not UniversalFragment: return BulletinHelper.show_error("Design Studio недоступен в данной версии клиента")
            delegate = IconSelectorDelegate(lambda name: (self.plugin.set_setting("ds_icon_res", name), self._update_preview_from_settings(animate=False))); fragment = UniversalFragment(delegate); delegate.fragment = fragment; self.base_fragment.presentFragment(fragment)
        except Exception as e: self.plugin.log(f"ICON SHEET ERROR: {e}")

class ReMeowLib(BasePlugin):
    BANNER_URL = "https://raw.githubusercontent.com/Yareks/plugins/main/banner.png"

    def on_plugin_load(self):
        self._is_running = True
        if is_safe_mode(): mlog("SAFE MODE ACTIVE: ReMeow Core will not load native extensions."); return
        mlog("Plugin initializing..."); (sys.modules.update({"ReMeow": sys.modules[self.__class__.__module__]}) if self.__class__.__module__ in sys.modules else None)
        
        loader = ReLoad.get()
        banner_path = os.path.join(loader.root, "dwd_banner.png")
        threading.Thread(target=lambda: SafeDownloader.download(self.BANNER_URL, banner_path), daemon=True).start()
        
        try:
            Class = jclass("java.lang.Class")
            try:
                sheet_target = Class.forName("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet")
                sheet_ctors = sheet_target.getDeclaredConstructors()
                if sheet_ctors and len(sheet_ctors) > 0:
                    self.hook_method(sheet_ctors[0], InstallSheetHook(self))
            except Exception as ex_h1:
                mlog(f"Hooking failed: InstallSheet {ex_h1}")
            
            try:
                engine_target = Class.forName("com.exteragram.messenger.plugins.PythonPluginsEngine")
                try:
                    m_is_plugin = engine_target.getDeclaredMethod("isPlugin", jarray(Class)([jclass("java.io.File").getClass(), jclass("org.telegram.messenger.MessageObject").getClass()]))
                    self.hook_method(m_is_plugin, Plugin2IsPluginHook(self))
                except: pass
                
                try:
                    params_target = Class.forName("com.exteragram.messenger.plugins.ui.components.InstallPluginBottomSheet$PluginInstallParams")
                    m_install = engine_target.getDeclaredMethod("showInstallDialog", jarray(Class)([jclass("org.telegram.ui.ActionBar.BaseFragment").getClass(), params_target]))
                    self.hook_method(m_install, Plugin2InstallHook(self))
                except: pass
                
                try:
                    m_share = engine_target.getDeclaredMethod("sharePlugin", jarray(Class)([jclass("java.lang.String").getClass()]))
                    self.hook_method(m_share, Plugin2ShareHook(self))
                except: pass
                
            except Exception as ex_h2:
                mlog(f"Hooking failed: EngineHooks {ex_h2}")
                
        except Exception as e: mlog(f"Global Hooking Error: {e}")
        
        self.banner_list = []
        self.last_banner_path = ""
        self.available_updates_cache = []
        self.last_banner_iv = None
        
        self._refresh_banner_list()
        self._check_and_install_deps_ui()
        
        threading.Thread(target=self._perform_initial_check, daemon=True).start()
        threading.Thread(target=self._precache_stickers, daemon=True).start()
        threading.Thread(target=self._start_banner_rotation, daemon=True).start()

    def on_plugin_unload(self):
        self._is_running = False

    def _perform_initial_check(self, silent=True):
        global _UPDATE_SHOWN_THIS_SESSION
        mlog("ReMeow: Синхронизация манифеста...")
        try:
            manifest_url = "https://raw.githubusercontent.com/Yareks/plugins/main/plugin.txt"
            res = requests.get(manifest_url, timeout=15)
            if res.status_code != 200: return
            
            lines = res.text.splitlines()
            updates_list = []
            
            remote_rem_url = None
            remote_wg_u, remote_wg_r, remote_wg_p = None, None, None

            for line in lines:
                if " - " not in line: continue
                key, val = [x.strip() for x in line.split(" - ", 1)]
                
                if key == "Lib":
                    remote_rem_url = val
                    if not remote_rem_url.startswith("http"):
                        p = remote_rem_url.split("/", 2)
                        if len(p) >= 3: remote_rem_url = f"https://raw.githubusercontent.com/{p[0]}/{p[1]}/main/{p[2]}"
                elif key == "MeowWG":
                    p = val.split("/")
                    if len(p) >= 3: remote_wg_u, remote_wg_r, remote_wg_p = p[0], p[1], "/".join(p[2:])
                elif key == "Banner":
                    banner_links = [x.strip() for x in val.split(",")]
                    for link in banner_links:
                        p = link.split("/", 2)
                        if len(p) >= 3:
                            url = f"https://raw.githubusercontent.com/{p[0]}/{p[1]}/main/{p[2]}"
                            filename = p[2].split("/")[-1]
                            dest = os.path.join(ReLoad.get().root, filename)
                            if not os.path.exists(dest):
                                threading.Thread(target=SafeDownloader.download, args=(url, dest), daemon=True).start()
                    self._refresh_banner_list()

            if remote_rem_url:
                try:
                    r_res = requests.get(remote_rem_url, timeout=10)
                    if r_res.status_code == 200:
                        m = re.search(r'__version__\s*=\s*"(.*?)"', r_res.text)
                        if m:
                            remote_rem_ver = m.group(1)
                            if remote_rem_ver != __version__:
                                updates_list.append({
                                    'id': 'remeow', 'name': 'ReMeow Lib', 'old': __version__, 'new': remote_rem_ver,
                                    'icon_str': 'Plugin2/1', 'url': remote_rem_url
                                })
                except: pass

            if remote_wg_u:
                try:
                    PC = jclass("com.exteragram.messenger.plugins.PluginsController").getInstance()
                    wg_p = PC.plugins.get("MeowWG")
                    local_wg_v = str(wg_p.getVersion()) if wg_p else "0.0.0"
                    
                    raw_wg = f"https://raw.githubusercontent.com/{remote_wg_u}/{remote_wg_r}/main/{remote_wg_p}"
                    wg_res = requests.get(raw_wg, timeout=10)
                    if wg_res.status_code == 200:
                        m = re.search(r'__version__\s*=\s*"(.*?)"', wg_res.text)
                        if m:
                            remote_wg_ver = m.group(1)
                            if remote_wg_ver != local_wg_v:
                                updates_list.append({
                                    'id': 'meowwg', 'name': 'MeowWG', 'old': local_wg_v, 'new': remote_wg_ver,
                                    'icon_str': 'Plugin2/0', 'u': remote_wg_u, 'r': remote_wg_r, 'p': remote_wg_p
                                })
                except: pass

            self.available_updates_cache = updates_list

            if updates_list and (not silent or not _UPDATE_SHOWN_THIS_SESSION):
                def show_sheet():
                    act = jclass("org.telegram.ui.LaunchActivity").instance
                    if not act:
                        frag = get_last_fragment()
                        if frag: act = frag.getParentActivity()
                    if act: UpdateNotificationSheet(act, updates_list, self._execute_updates).show()
                run_on_ui_thread(show_sheet)

        except Exception as e: mlog(f"Check update error: {e}")

    def _execute_updates(self):
        BulletinHelper.show_info("Запуск процесса обновления...")
        for upd in self.available_updates_cache:
            if upd['id'] == 'remeow':
                threading.Thread(target=self._update_self, args=(upd['url'],), daemon=True).start()
            elif upd['id'] == 'meowwg':
                threading.Thread(target=self._gh_start_download, args=(upd['u'], upd['r'], upd['p'], "ReMeow_Companion"), kwargs={'enable_after': True}, daemon=True).start()

    def _update_self(self, url):
        try:
            tmp = os.path.join(ReLoad.get().root, "rem_upd.tmp")
            if not SafeDownloader.download(url, tmp): return
            
            my_path = self._find_self_path(__id__)
            if not my_path: 
                mlog("Update failed: Path to self not found!")
                return
            
            try:
                shutil.copyfile(tmp, my_path)
            except PermissionError:
                with open(tmp, 'rb') as src, open(my_path, 'wb') as dst:
                    dst.write(src.read())
            
            if os.path.exists(tmp): os.remove(tmp)
            run_on_ui_thread(lambda: BulletinHelper.show_success("ReMeow обновлен! Перезапустите приложение."))
        except Exception as e: 
            mlog(f"Self update error: {e}")
            run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка обновления! См. логи."))

    def _find_self_path(self, plugin_id):
        try:
            PC = jclass("com.exteragram.messenger.plugins.PluginsController").getInstance()
            engine = PC.engines.get("python")
            if engine:
                path = engine.getPluginPath(plugin_id)
                if path: return str(path)

            ctx = jclass("org.telegram.messenger.ApplicationLoader").applicationContext
            search_dirs = [
                os.path.join(str(ctx.getFilesDir()), "plugins"),
                os.path.join(str(ctx.getFilesDir()), "AyuGram Files"),
                "/storage/emulated/0/Android/data/" + str(ctx.getPackageName()) + "/files/Exteragram Files/",
            ]
            
            for base_dir in search_dirs:
                if os.path.exists(base_dir):
                    for f in os.listdir(base_dir):
                        if f.endswith(".plugin") or f.endswith(".py"):
                            f_p = os.path.join(base_dir, f)
                            with open(f_p, 'r', encoding='utf-8', errors='ignore') as pf:
                                head = pf.read(1024)
                                if f'__id__ = "{plugin_id}"' in head or f'__id__="{plugin_id}"' in head:
                                    return f_p
        except Exception as e: mlog(f"Self-path search error: {e}")
        return None

    def _gh_start_download(self, user, repo, path, folder_name, branch="main", enable_after=False) -> bool:
        clean_path = path
        if clean_path.startswith(f"{user}/{repo}/"):
            clean_path = clean_path[len(f"{user}/{repo}/"):]
            
        raw_url = f"https://raw.githubusercontent.com/{user}/{repo}/{branch}/{clean_path}"
        dest_dir = os.path.join(str(Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOWNLOADS).getAbsolutePath()), folder_name)
        if not os.path.exists(dest_dir): os.makedirs(dest_dir)
        dest = os.path.join(dest_dir, clean_path.split("/")[-1])
        
        success = SafeDownloader.download(raw_url, dest)
        if not success and branch == "main":
            return self._gh_start_download(user, repo, clean_path, folder_name, branch="master", enable_after=enable_after)
        if success:
            run_on_ui_thread(lambda: BulletinHelper.show_success(f"Загружено в Downloads/{folder_name}"))
            if dest.lower().endswith(".plugin"):
                try:
                    PC = jclass("com.exteragram.messenger.plugins.PluginsController").getInstance()
                    engine = PC.engines.get("python")
                    if engine:
                        class EnableCallback(dynamic_proxy(jclass("org.telegram.messenger.Utilities$Callback"))):
                            def __init__(self, plugin_id):
                                super().__init__()
                                self.plugin_id = plugin_id
                            def run(self, error):
                                if not error and enable_after:
                                    def enable_plugin():
                                        time.sleep(1.5)
                                        PC.setPluginEnabled(self.plugin_id, True, None)
                                    threading.Thread(target=enable_plugin, daemon=True).start()
                        engine.loadPluginFromFile(dest, None, EnableCallback("MeowWG"))
                except: pass
        return success

    def _start_banner_rotation(self):
        while self._is_running:
            time.sleep(11)
            self._refresh_banner_list()
            valid_banners = [p for p in self.banner_list if p and os.path.exists(p)]
            if len(valid_banners) < 2:
                continue
            candidates = [p for p in valid_banners if p != self.last_banner_path]
            new_banner = random.choice(candidates)
            self.last_banner_path = new_banner
            self._apply_banner_with_fade(new_banner)

    def _apply_banner_with_fade(self, path):
        if not hasattr(self, 'last_banner_iv') or self.last_banner_iv is None:
            self.last_banner_path = path
            return

        def _task():
            try:
                if not os.path.exists(path): return
                bmp = BitmapFactory.decodeFile(path)
                if not bmp: return
                iv = self.last_banner_iv
                iv.animate().alpha(0.0).setDuration(600).withEndAction(ActionRunnable(lambda: (
                    iv.setImageBitmap(bmp),
                    iv.animate().alpha(1.0).setDuration(600).start()
                ))).start()
            except Exception as e:
                mlog(f"Banner fade error: {e}")
        run_on_ui_thread(_task)

    def _refresh_banner_list(self):
        try:
            loader = ReLoad.get()
            banner_dir = loader.root
            if not os.path.exists(banner_dir): return
            banners = [os.path.join(banner_dir, f) for f in os.listdir(banner_dir)
                       if f.lower().endswith('.png') and os.path.isfile(os.path.join(banner_dir, f))]
            if not banners:
                default_path = os.path.join(banner_dir, "dwd_banner.png")
                if os.path.exists(default_path): banners.append(default_path)
            self.banner_list = banners
        except Exception as e:
            mlog(f"Refresh banner list error: {e}")

    def download_from_github(self, user, repo, path, folder_name, branch="main", callback=None):
        def _task(): success = self._gh_start_download(user, repo, path, folder_name, branch); (callback(success) if callback else None)
        run_on_queue(_task)

    def _check_and_install_deps_ui(self):
        site_pkgs = RePip.get_dirs()[1]
        (sys.path.insert(0, site_pkgs) if site_pkgs not in sys.path else None)
        try: RePip.fix_cffi_backend(); import cffi; _CFFI_READY.set()
        except: _CFFI_READY.clear(); threading.Thread(target=self._wait_and_show_installer).start()

    def _wait_and_show_installer(self):
        act = None
        for _ in range(20):
            try: (act := jclass("org.telegram.ui.LaunchActivity").instance)
            except: pass
            if act: break
            time.sleep(0.5)
        (run_on_ui_thread(lambda: CoreInstallerSheet(act).show()) if act else threading.Timer(10.0, _CFFI_READY.set).start())

    def _get_banner_view(self):
        ctx = jclass("org.telegram.messenger.ApplicationLoader").applicationContext
        loader = ReLoad.get()
        if not hasattr(self, 'last_banner_path') or not self.last_banner_path:
            self._refresh_banner_list()
            if self.banner_list and os.path.exists(self.banner_list[0]):
                self.last_banner_path = self.banner_list[0]
            else:
                self.last_banner_path = os.path.join(loader.root, "dwd_banner.png")
        container = FrameLayout(ctx)
        iv = ImageView(ctx)
        iv.setScaleType(ImageView.ScaleType.CENTER_CROP)
        self.last_banner_iv = iv
        if os.path.exists(self.last_banner_path):
            bmp = BitmapFactory.decodeFile(self.last_banner_path)
            if bmp: iv.setImageBitmap(bmp)
            else: iv.setBackgroundColor(0xFF222222)
        else: iv.setBackgroundColor(0xFF222222)
        container.addView(iv, LayoutHelper.createFrame(-1, 160))
        return container

    def create_settings(self):
        return [
            Custom(view=self._get_banner_view()), 
            Header(text=f"ReMeow Core v{__version__}"), 
            Text(text="Список модулей", icon="msg_bot", subtext="Интегрированные плагины", create_sub_fragment=self._modules_list_page),
            Text(text="Дизайн", icon="msg_palette", create_sub_fragment=self._design_sub_page), 
            Header(text="Синхронизация"),
            Text(text="Проверить обновления", icon="msg_download", on_click=lambda v: threading.Thread(target=self._perform_initial_check, args=(False,), daemon=True).start()),
            Header(text="Дополнительно"), 
            Text(text="Управление ядром & Очистка", icon="msg_settings", create_sub_fragment=self._modules_sub_page),
            Text(text="Справка разработчика & API", icon="msg_help", create_sub_fragment=self._others_sub_page), 
            Divider()
        ]

    def _modules_list_page(self):
        loader = ReLoad.get()
        items = []
        items.append(Header(text="Активные модули"))
        
        if not loader.registered_modules:
            items.append(Text(text="Нет активных модулей", red=True))
            return items

        for pid, data in loader.registered_modules.items():
            # Замыкаем переменные через аргументы функции
            def open_mod_page(p=pid, d=data):
                def run():
                    # Создаем делегат с данными конкретного модуля
                    delegate = ModuleInfoDelegate(p, d)
                    # Создаем фрагмент через UniversalFragment
                    frag = UniversalFragment(delegate)
                    # Безопасно открываем
                    get_last_fragment().presentFragment(frag)
                run_on_ui_thread(run)

            items.append(Text(
                text=data['name'], 
                subtext=f"{data['status']} | v{data['ver']}",
                icon="msg_bot",
                on_click=lambda v, f=open_mod_page: f()
            ))
            
        return items
    def _show_delete_dialog(self, p_id, name):
        """Вспомогательный метод для отображения диалога удаления"""
        loader = ReLoad.get()
        
        def perform_del():
            # 1. Удаляем файл модуля
            path = self._find_self_path(p_id)
            if path and os.path.exists(path):
                try:
                    os.remove(path)
                    mlog(f"Файл {path} удален.")
                except Exception as e:
                    mlog(f"Ошибка при удалении файла: {e}")
            
            # 2. Удаляем из памяти
            if p_id in loader.registered_modules:
                del loader.registered_modules[p_id]
            
            # 3. Уведомление
            run_on_ui_thread(lambda: BulletinHelper.show_success(f"Модуль {name} удален. Перезапустите клиент."))
            # Можно принудительно обновить фрагмент, если нужно
            try: get_last_fragment().finishFragment()
            except: pass

        # Создаем диалог
        act = jclass("org.telegram.ui.LaunchActivity").instance
        if not act: return

        builder = AlertDialog.Builder(act)
        builder.setTitle("Удаление модуля")
        builder.setMessage(f"Вы уверены, что хотите удалить модуль '{name}'?")
        builder.setPositiveButton("Удалить", ActionRunnable(perform_del))
        builder.setNegativeButton("Отмена", None)
        builder.show()
    def _others_sub_page(self):
        doc_snippet = """# ReMeow Module API Guide

1. ИНИЦИАЛИЗАЦИЯ
Всегда вызывайте ReMeowCore.initialize(self) в on_plugin_load.
Чтобы ReMeow зарегистрировал вас как модуль:
rem = sys.modules.get('ReMeow')
rem.ReMeowCore.register_module(self, name="MyModule", version="1.0", status="Работаю", ui_provider=self.get_remeow_ui)

2. GITHUB & ЗАГРУЗКИ
Вы можете использовать ReMeow для скачивания файлов/плагинов:
rem.download_from_github('User', 'Repo', 'path/file.plugin', 'FolderInDownloads')
Файл будет сохранен в папку 'FolderInDownloads' внутри Downloads.

3. КАСТОМНЫЙ БАННЕР
Если хотите добавить свой баннер в ротацию ReMeow:
# Скачайте PNG файл в ReLoad.get().root и ReMeow подхватит его автоматически.

4. UI & ВЗАИМОДЕЙСТВИЕ
В ui_provider (get_remeow_ui) возвращайте список элементов настроек:
def get_remeow_ui(self):
    return [Header(text="Настройки модуля"), Switch(...)]

5. ОБНОВЛЕНИЕ СТАТУСА
Вы можете менять статус динамически:
rem.ReMeowCore.update_module_status(self, "Загрузка данных...")
"""
        return [
            Header(text="Справка разработчика"), 
            Custom(view=self._get_doc_view(doc_snippet)),
            Header(text="Тест GitHub API"),
            Input(key="api_gh_full_path", text="Путь (User/Repo/Branch/File)", default=""),
            Input(key="api_gh_folder", text="Папка назначения", default="ReMeow_Downloads"),
            Text(text="Начать загрузку", icon="msg_download", on_click=self._manual_gh_dl),
            Divider()
        ]

    def _manual_gh_dl(self, v):
        full_path = self.get_setting("api_gh_full_path", "")
        folder = self.get_setting("api_gh_folder", "ReMeow_Downloads")
        if "/" not in full_path: return BulletinHelper.show_error("Неверный путь!")
        parts = full_path.split("/", 3)
        if len(parts) < 3: return BulletinHelper.show_error("Укажите как минимум User/Repo/File")
        u, r = parts[0], parts[1]
        b, p = (parts[2], parts[3]) if len(parts) == 4 else ("main", parts[2])
        BulletinHelper.show_info("Загрузка...")
        self.download_from_github(u, r, p, folder, b)

    def _get_doc_view(self, text):
        ctx = jclass("org.telegram.messenger.ApplicationLoader").applicationContext
        root = LinearLayout(ctx); root.setOrientation(1); root.setPadding(AndroidUtilities.dp(16), AndroidUtilities.dp(8), AndroidUtilities.dp(16), AndroidUtilities.dp(8))
        badge = LinearLayout(ctx); badge.setOrientation(0); badge.setGravity(17)
        badge.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AndroidUtilities.dp(12), ColorUtils.blendARGB(Theme.getColor(Theme.key_windowBackgroundWhite), Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader), 0.1), ColorUtils.blendARGB(Theme.getColor(Theme.key_windowBackgroundWhite), Theme.getColor(Theme.key_windowBackgroundWhiteBlackText), 0.1)))
        badge.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(8), AndroidUtilities.dp(12), AndroidUtilities.dp(8))
        t = jclass("android.widget.TextView")(ctx); t.setText("ИНСТРУКЦИЯ API"); t.setTypeface(AndroidUtilities.bold()); t.setTextSize(1, 12.0); t.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader))
        badge.addView(t); wrapper = LinearLayout(ctx); wrapper.setOrientation(1); wrapper.setVisibility(8); wrapper.setPadding(0, AndroidUtilities.dp(10), 0, AndroidUtilities.dp(10))
        content = jclass("android.widget.TextView")(ctx); content.setText(text); content.setTextSize(1, 12.0); content.setTypeface(jclass("android.graphics.Typeface").MONOSPACE); content.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
        content.setBackground(Theme.createRoundRectDrawable(AndroidUtilities.dp(8), Theme.getColor(Theme.key_windowBackgroundGray))); content.setPadding(AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12), AndroidUtilities.dp(12))
        content.setOnLongClickListener(OnLongClickProxy(lambda v: (AndroidUtilities.addToClipboard(text), BulletinHelper.show_success("API Гайд скопирован!"), True)[2]))
        wrapper.addView(content); root.addView(badge); root.addView(wrapper)
        badge.setOnClickListener(OnClickProxy(lambda v: (wrapper.setVisibility(8 if wrapper.getVisibility() == 0 else 0))))
        return root

    def _modules_sub_page(self):
        kill = lambda v: (jclass("org.telegram.ui.LaunchActivity").instance.finishAffinity() if jclass("org.telegram.ui.LaunchActivity").instance else None, jclass("java.lang.System").exit(0))
        def clear(v):
            root = ReLoad.get().root; (shutil.rmtree(root) if os.path.exists(root) else None); os.makedirs(root); BulletinHelper.show_success("Очищено! Перезапустите приложение.")
        return [
            Header(text="Управление процессом"), 
            Text(text="Перезапустить приложение", icon="msg_settings", red=True, on_click=kill),
            Header(text="Очистка"),
            Text(text="Очистить все данные ReMeow", icon="msg_delete", red=True, on_click=clear)
        ]

    def _design_sub_page(self):
        v_box, sync = [None], threading.Event()
        def build():
            frag = get_last_fragment(); ctx = frag.getParentActivity() if frag else None
            if ctx: v_box[0] = DesignStudioController(ctx, self, frag).get_view()
            sync.set()
        run_on_ui_thread(build); sync.wait(3.0)
        return ([Custom(view=v_box[0])] if v_box[0] else [Text(text="Ошибка загрузки Design Studio", red=True)])

    def _precache_stickers(self):
        try:
            TLRPC, CM, UC = jclass("org.telegram.tgnet.TLRPC"), jclass("org.telegram.tgnet.ConnectionsManager"), jclass("org.telegram.messenger.UserConfig")
            req = TLRPC.TL_messages_getStickerSet(); req.stickerset = TLRPC.TL_inputStickerSetShortName(); req.stickerset.short_name = "UtyaDuck"; req.hash = 0 
            CM.getInstance(UC.selectedAccount).sendRequest(req, None)
        except: pass

    def on_send_message_hook(self, account, params):
        return HookResult()

class ModuleDetailsDelegate(dynamic_proxy(UniversalFragmentDelegate) if UniversalFragmentDelegate else object):
    def __init__(self, pid):
        super().__init__()
        self.pid = pid
        self.data = ReLoad.get().registered_modules.get(pid, {})
        
    def getTitle(self): return self.data.get("name", "Модуль")
    def fillItems(self, items, adapter):
        if not self.data:
            items.add(Header(text="Данные не найдены"))
            return
            
        items.add(Header(text="Информация о модуле"))
        items.add(Text(text="Версия", subtext=self.data['ver']))
        items.add(Text(text="Статус", subtext=self.data['status']))
        
        ui_cb = self.data.get("ui_cb")
        if ui_cb and callable(ui_cb):
            try:
                module_items = ui_cb()
                if module_items:
                    items.add(Header(text="Настройки модуля"))
                    for i in module_items: items.add(i)
            except Exception as e:
                mlog(f"Module UI provider error ({self.pid}): {e}")
                items.add(Text(text="Ошибка загрузки настроек", red=True))


class ModuleInfoDelegate(dynamic_proxy(UniversalFragmentDelegate) if UniversalFragmentDelegate else object):
    def __init__(self, pid, data):
        super().__init__()
        self.pid = pid
        self.data = data # Словарь с инфой модуля
        
    def getTitle(self): 
        return self.data.get("name", "Информация")

    def fillItems(self, items, adapter):
        # 1. Базовая информация
        items.add(Header(text="Общая информация"))
        items.add(Text(text="Название", subtext=self.data.get("name", "N/A")))
        items.add(Text(text="Версия", subtext=self.data.get("ver", "N/A")))
        items.add(Text(text="Статус", subtext=self.data.get("status", "N/A")))
        
        # 2. Кастомный UI (если модуль предоставляет)
        ui_cb = self.data.get("ui_cb")
        if ui_cb and callable(ui_cb):
            items.add(Header(text="Настройки модуля"))
            try:
                module_ui = ui_cb()
                for item in module_ui:
                    items.add(item)
            except Exception as e:
                mlog(f"Error loading module UI: {e}")
                items.add(Text(text="Ошибка загрузки настроек", red=True))

    def onFragmentCreate(self): return True
    def onFragmentDestroy(self): pass
    def onBackPressed(self): return True
    def onMenuItemClick(self, id): pass
    def onClick(self, item, view, position, x, y): pass
    def onLongClick(self, item, view, position, x, y): return False
    def beforeCreateView(self): return None
    def afterCreateView(self, view): pass
