        self.current_target = type_str; self.settings_container.animate().alpha(0.0).translationY(float(AndroidUtilities.dp(20))).setDuration(150).withEndAction(ActionRunnable(self._build_settings_panel)).start()

    def _build_settings_panel(self):
        try:
            self.settings_container.removeAllViews()
            if self.current_target == 'container': self._add_title("Настройки контейнера"); self._add_toggle_btn("ds_cont_enabled", True); self._add_color_picker("Цвет контейнера", "ds_cont_color", Theme.getColor(Theme.key_windowBackgroundGray)); self._add_slider("Скругление (dp)", "ds_cont_radius", 0, 32, 16)
            elif self.current_target == 'icon': self._add_title("Иконка зависимости"); self._add_icon_selector_btn()
            elif self.current_target == 'req_text': self._add_title("Обязательный модуль"); self._add_color_picker("Цвет заголовка", "ds_req_title_color", Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)); self._add_input("Текст подписи", "ds_req_sub_text", "Обязательно"); self._add_color_picker("Цвет подписи", "ds_req_sub_color", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)); self._add_alignment_control("Выравнивание текста", "ds_req_gravity", 3)
            elif self.current_target == 'opt_text': self._add_title("Опциональный модуль"); self._add_color_picker("Цвет заголовка", "ds_opt_title_color", Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)); self._add_input("Текст подписи", "ds_opt_sub_text", "Опционально"); self._add_color_picker("Цвет подписи", "ds_opt_sub_color", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText)); self._add_alignment_control("Выравнивание текста", "ds_opt_gravity", 3)
            elif self.current_target == 'req_checkbox': self._add_title("Чекбокс (Обязательный)"); self._add_slider_float("Масштаб галочки (0.5x - 1.5x)", "ds_req_cb_scale", 0.5, 1.5, 1.0); self._add_slider("Размер рамки (dp)", "ds_req_cb_frame", 16, 50, 26)
            elif self.current_target == 'opt_checkbox': self._add_title("Чекбокс (Опциональный)"); self._add_slider_float("Масштаб галочки (0.5x - 1.5x)", "ds_opt_cb_scale", 0.5, 1.5, 1.0); self._add_slider("Размер рамки (dp)", "ds_opt_cb_frame", 16, 50, 26)
            elif self.current_target is None: tv = jclass("android.widget.TextView")(self.context); tv.setText("Нажмите на любой элемент выше для его настройки"); tv.setTextColor(jint(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))); tv.setGravity(17); self.settings_container.addView(tv, LayoutHelper.createLinear(-1, -2, 0, 16, 40, 16, 0))
            self.settings_container.setTranslationY(float(AndroidUtilities.dp(20))); self.settings_container.animate().alpha(1.0).translationY(0.0).setDuration(200).setInterpolator(jclass("org.telegram.ui.Components.CubicBezierInterpolator").EASE_OUT_QUINT).start()
        except Exception as e: self.plugin.log(f"BUILD SETTINGS ERROR: {e}")

