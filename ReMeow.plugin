        x, y = self.loc_target[0] - self.loc_view[0], self.loc_target[1] - self.loc_view[1]
        self.target_rect.set(float(x), float(y), float(x + target_view.getWidth()), float(y + target_view.getHeight()))
        if self.current_rect.isEmpty(): self.current_rect.set(self.target_rect); self.view.invalidate()
