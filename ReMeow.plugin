_CFFI_READY = threading.Event()
_CFFI_REINSTALL_LOCK = threading.Lock()
_UPDATE_SHOWN_THIS_SESSION = False

def mlog(msg):
    log(f"[ReMeow] {msg}")

def is_safe_mode() -> bool:
    try:
        ExteraConfig = jclass("com.exteragram.messenger.ExteraConfig")
        return bool(getattr(ExteraConfig, "pluginsSafeMode", False))
    except:
        return False

def safe_jclass(path):
    try:
        return jclass(path)
    except:
        return None

class SafeDownloader:
    @staticmethod
    def download(url: str, dest_path: str, progress_cb=None) -> bool:
        tmp_path = dest_path + ".tmp"
        try:
            if os.path.exists(tmp_path):
                os.remove(tmp_path)
            
            os.makedirs(os.path.dirname(dest_path), exist_ok=True)

            with requests.get(url, stream=True, timeout=30) as r:
                r.raise_for_status()
                total_size = int(r.headers.get('content-length', 0))
                downloaded = 0
                
                with open(tmp_path, 'wb') as f:
                    for chunk in r.iter_content(chunk_size=8192):
                        if chunk:
                            f.write(chunk)
                            downloaded += len(chunk)
                            if progress_cb and total_size > 0:
                                progress_cb(downloaded, total_size)
                
                if downloaded < 100: 
                     raise ValueError("File is too small or empty")

            if os.path.exists(dest_path): os.remove(dest_path)
            os.rename(tmp_path, dest_path)
            return True

        except Exception as e:
            mlog(f"SafeDownloader Error: {e} | URL: {url}")
            if os.path.exists(tmp_path):
                try: os.remove(tmp_path)
                except: pass
            return False

class RePip:
    WHEELS_CORE = {
        "setuptools": "https://files.pythonhosted.org/packages/a3/dc/17031897dae0efacfea57dfd3a82fdd2a2aeb58e0ff71b77b87e44edc772/setuptools-80.9.0-py3-none-any.whl",
        "pip": "https://files.pythonhosted.org/packages/44/3c/d717024885424591d5376220b5e836c2d5293ce2011523c9de23ff7bf068/pip-25.3-py3-none-any.whl",
        "wheel": "https://files.pythonhosted.org/packages/0b/2c/87f3254fd8ffd29e4c02732eee68a83a1d3c346ae39bc6822dcbcb697f2b/wheel-0.45.1-py3-none-any.whl",
    }
    
    PYCPARSER_URL = "https://github.com/coidarashka/MandreLib-Modules/releases/download/PIP/pycparser-3.0-py3-none-any.whl"
    CFFI_URL = "https://github.com/coidarashka/MandreLib-Modules/releases/download/PIP/cffi-2.0.0-cp311-cp311-android_30_arm64_v8a.whl"

    @staticmethod
    def get_dirs():
        base = ReLoad.get().root
        pip_base = os.path.join(base, "pip_core")
        site_packages = os.path.join(base, "site-packages") 
        wheels_cache = os.path.join(pip_base, "wheels")
        for d in [pip_base, site_packages, wheels_cache]:
            if not os.path.exists(d): os.makedirs(d)
        return pip_base, site_packages, wheels_cache

    @staticmethod
    def bootstrap():
        if is_safe_mode(): return False
        try:
            _, site_pkgs, wheel_cache = RePip.get_dirs()
            if site_pkgs not in sys.path: sys.path.insert(0, site_pkgs)
            try:
                import pip
                return True
            except ImportError:
                mlog("RePip: Bootstrapping pip...")

            for name, url in RePip.WHEELS_CORE.items():
                fname = os.path.join(wheel_cache, url.split("/")[-1])
                if not os.path.exists(fname) or os.path.getsize(fname) < 1024:
                    mlog(f"RePip: Downloading core {name}...")
                    if not SafeDownloader.download(url, fname):
                        return False

                with zipfile.ZipFile(fname) as zf:
                    zf.extractall(site_pkgs)
            importlib.invalidate_caches()
            import pip
            mlog("RePip: Bootstrap complete.")
            return True
        except Exception as e:
            mlog(f"RePip Bootstrap Error: {e}")
            return False

    @staticmethod
    def ensure_pycparser():
        try:
            import pycparser
            return True
        except ImportError:
            mlog("RePip: Installing pycparser...")
            return RePip.install_wheel_direct(RePip.PYCPARSER_URL, "pycparser")

    @staticmethod
    def _expose_python_symbols():
        if is_safe_mode(): return False
        try:
            ver = f"{sys.version_info.major}.{sys.version_info.minor}"
            lib_name = f"libpython{ver}.so"
            found_path = None
            try:
                with open("/proc/self/maps", "r") as f:
                    for line in f:
                        if lib_name in line:
                            parts = line.split()
                            if len(parts) >= 6:
                                path = parts[5]
                                if path.endswith(".so"):
                                    found_path = path
                                    break
            except: pass
            target_lib = found_path if found_path else lib_name
            mode_flags = 0x100 | 0x2
            ctypes.CDLL(target_lib, mode=mode_flags)
            return True
        except Exception as e:
            return False

    @staticmethod
    def fix_cffi_backend():
        if is_safe_mode(): return False
        RePip._expose_python_symbols()
        if '_cffi_backend' in sys.modules: return True
        
        _, site_pkgs, _ = RePip.get_dirs()
        if not os.path.exists(site_pkgs): return False
        
        try:
            so_path = None
            for root, dirs, files in os.walk(site_pkgs):
                for f in files:
                    if f.startswith("_cffi_backend") and f.endswith(".so"):
                        so_path = os.path.join(root, f)
                        break
                if so_path: break
                
            if so_path:
                linker = NativeLinker()
                lib = linker.load(so_path, is_python_ext=True)
                if lib and hasattr(lib, "PyInit__cffi_backend"):
                    init_func = getattr(lib, "PyInit__cffi_backend")
                    init_func.restype = ctypes.py_object
                    sys.modules['_cffi_backend'] = init_func()
                    mlog(f"RePip: Bypassed Android W^X restriction for {os.path.basename(so_path)}")
                    return True
        except Exception as e:
            mlog(f"RePip: Backend fix error: {e}")
        return False

    @staticmethod
    def install_wheel_direct(url, package_name):
        if is_safe_mode() or not RePip.bootstrap(): return False
        
        _, site_pkgs, wheel_cache = RePip.get_dirs()
        fname = os.path.join(wheel_cache, url.split("/")[-1])

        if not os.path.exists(fname) or os.path.getsize(fname) < 1024:
            mlog(f"RePip: Downloading {package_name} from URL...")
            if not SafeDownloader.download(url, fname):
                mlog(f"RePip: Failed to download {package_name}")
                return False

        mlog(f"RePip: Installing {package_name}...")
        try:
            import contextlib
            from io import StringIO
            output = StringIO()
            
            py_ver = f"{sys.version_info.major}{sys.version_info.minor}"
            args = [
                "install", fname, "--target", site_pkgs, 
                "--no-deps", "--no-index", "--force-reinstall", "--no-warn-script-location",
                "--platform", "android_30_arm64_v8a",
                "--implementation", "cp",
                "--python-version", py_ver,
                "--abi", f"cp{py_ver}",
                "--only-binary", ":all:"
            ]
            
            with contextlib.redirect_stdout(output), contextlib.redirect_stderr(output):
                import pip
                if hasattr(pip, "main"): pip.main(args)
                else: 
                    from pip._internal.cli.main import main as pip_main
                    pip_main(args)
            
            out_str = output.getvalue()
            if "Successfully installed" in out_str or "Requirement already satisfied" in out_str:
                mlog(f"RePip: {package_name} installed successfully.")
                return True
            else:
                mlog(f"RePip Install Failed. Pip output:\n{out_str}")
                try: os.remove(fname)
                except: pass
                return False
                
        except Exception as e:
            mlog(f"RePip Install Error (Exception): {e}")
            return False

class NativeLinker:
    def __init__(self):
        self.libdl = ctypes.CDLL("libdl.so")
        try:
            self.open_ext = self.libdl.android_dlopen_ext
            class Info(ctypes.Structure):
                _fields_ = [("flags", ctypes.c_uint64), ("reserved_addr", ctypes.c_void_p), ("reserved_size", ctypes.c_size_t), ("relro_fd", ctypes.c_int), ("library_fd", ctypes.c_int), ("library_fd_offset", ctypes.c_uint64), ("library_namespace", ctypes.c_void_p)]
            self.Info = Info
            self.open_ext.argtypes = [ctypes.c_char_p, ctypes.c_int, ctypes.POINTER(self.Info)]
            self.open_ext.restype = ctypes.c_void_p
        except: 
            self.open_ext = None

    def load(self, path: str, is_python_ext: bool = False):
        if is_safe_mode(): return None
        if not os.path.exists(path) or os.path.getsize(path) < 1024: 
            mlog(f"NativeLinker: Path invalid or file too small: {path}")
            return None

        LoaderClass = ctypes.PyDLL if is_python_ext else ctypes.CDLL

        if Build.VERSION.SDK_INT >= 29 and self.open_ext:
            fd = os.open(path, os.O_RDONLY)
            try:
                info = self.Info(flags=0x10, library_fd=fd)
                h = self.open_ext(path.encode(), 2 | 0x100, ctypes.byref(info))
                if h: return LoaderClass(path, handle=h)
            except Exception as e: mlog(f"NativeLinker: ext_err {e}")
            finally: os.close(fd)
        try: return LoaderClass(path, mode=2 | 0x100)
        except Exception as e: 
            mlog(f"NativeLinker Error: {e}")
            return None

class ModuleGatekeeper:
    def __init__(self, loader):
        self.loader = loader

    def _check_access(self, key):
        if key not in self.loader._storage:
            return False, "Not loaded"

        try:
            frame = sys._getframe(2) 
            caller_id = frame.f_globals.get("__id__")

            if not caller_id or caller_id == "ReMeow":
                return True, None

            plugin_choices = self.loader.choices.get(caller_id, {})

            if plugin_choices.get(key) is False:
                return False, "User disabled this module"
                
            return True, None
        except:
            return True, None

    def __getitem__(self, key):
        allowed, reason = self._check_access(key)
        if not allowed:
            raise KeyError(f"Module '{key}' is hidden: {reason}")
        return self.loader._storage[key]

    def __contains__(self, key):
        allowed, _ = self._check_access(key)
        return allowed

    def get(self, key, default=None):
        try:
            return self[key]
        except KeyError:
            return default

    def keys(self): return self.loader._storage.keys()

class ReLoad:
    _instance = None
    def __init__(self):
        try:
            ctx = jclass("org.telegram.messenger.ApplicationLoader").applicationContext
            self.root = os.path.join(str(ctx.getFilesDir()), "remeow_modules")
        except: self.root = "/data/data/org.telegram.messenger/files/remeow_modules"
        if not os.path.exists(self.root): os.makedirs(self.root)
        
        self._storage = {}
        self.registered_modules = {} # id -> { instance, name, ver, status, ui_cb }
        self.loaded_modules = ModuleGatekeeper(self)
        
        p = os.path.join(self.root, "user_choices.json")
        if os.path.exists(p):
            try:
                with open(p, 'r', encoding='utf-8') as f:
                    self.choices = json.load(f)
            except:
                self.choices = {}
        else:
            self.choices = {}

    @staticmethod
    def get():
        if not ReLoad._instance: ReLoad._instance = ReLoad()
        return ReLoad._instance

    def save_choice(self, pid, mod, state):
        if pid not in self.choices: self.choices[pid] = {}
        self.choices[pid][mod] = state
        with open(os.path.join(self.root, "user_choices.json"), 'w') as f: json.dump(self.choices, f, ensure_ascii=False, indent=4)

class CryingSheet:
    def __init__(self, context, plugin_id):
        self.context = context
        self.plugin_id = plugin_id
        self.sheet = None
        try:
            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            self.sheet = BottomSheet(context, False)
            self.sheet.fixNavigationBar()
            
            AU = jclass("org.telegram.messenger.AndroidUtilities")
            LH = jclass("org.telegram.ui.Components.LayoutHelper")
            TV = jclass("android.widget.TextView")
            LL = jclass("android.widget.LinearLayout")
            SIV = jclass("org.telegram.ui.Components.StickerImageView")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            
            self.root = LL(context)
            self.root.setOrientation(1)
            self.root.setPadding(0, AU.dp(18), 0, AU.dp(18))
            
            try:
                self.sticker = SIV(context, 0)
                self.sticker.setStickerPackName("UtyaDuck")
                self.sticker.setStickerNum(13) 
                self.sticker.getImageReceiver().setAutoRepeat(1)
                self.root.addView(self.sticker, LH.createLinear(144, 144, 1, 0, 10, 0, 0))
            except: pass
            
            self.title = TV(context)
            self.title.setText("Всё пошло не так 😭")
            self.title.setTextSize(1, 20.0)
            self.title.setTypeface(AU.bold())
            self.title.setGravity(1)
            self.title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            self.root.addView(self.title, LH.createLinear(-1, -2, 1, 40, 15, 40, 0))
            
            self.description = TV(context)
            self.description.setText(f"ReMeow не смог инициализировать CFFI после всех попыток.\nПлагин '{self.plugin_id}' может работать нестабильно.")
            self.description.setTextSize(1, 14.0)
            self.description.setGravity(1)
            self.description.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            self.root.addView(self.description, LH.createLinear(-1, -2, 1, 35, 10, 35, 10))
            
            self.sheet.setCustomView(self.root)
        except Exception as e:
            mlog(f"Failed to create CryingSheet: {e}")

    def show(self):
        if self.sheet: self.sheet.show()

class UpdateNotificationSheet:
    def __init__(self, context, available_updates, on_update_all):
        self.context = context
        self.updates = sorted(available_updates, key=lambda x: 0 if x['id'] == 'remeow' else 1) 
        self.on_update_all = on_update_all
        self.sheet = None
        
        try:
            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            self.sheet = BottomSheet(context, False)
            self.sheet.fixNavigationBar()
            
            AU = jclass("org.telegram.messenger.AndroidUtilities")
            LH = jclass("org.telegram.ui.Components.LayoutHelper")
            TV = jclass("android.widget.TextView")
            LL = jclass("android.widget.LinearLayout")
            IV = jclass("android.widget.ImageView")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            SIV = jclass("org.telegram.ui.Components.StickerImageView")
            SV = jclass("android.widget.ScrollView")
            R_tg = jclass("org.telegram.messenger.R")
            
            self.root = LL(context)
            self.root.setOrientation(1)
            self.root.setPadding(0, AU.dp(20), 0, AU.dp(20))
            
            self.title = TV(context)
            self.title.setText("Найдено обновление:")
            self.title.setTextSize(1, 20.0)
            self.title.setTypeface(AU.bold())
            self.title.setGravity(1)
            self.title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            self.root.addView(self.title, LH.createLinear(-1, -2, 1, 40, 0, 40, 15))

            scroll = SV(context)
            scroll.setFillViewport(True)
            
            list_cont = LL(context)
            list_cont.setOrientation(1)
            list_cont.setPadding(AU.dp(24), 0, AU.dp(24), 0)
            
            PI = safe_jclass("com.exteragram.messenger.plugins.ui.PluginIcons")
            
            for upd in self.updates:
                row = LL(context)
                row.setOrientation(0)
                row.setGravity(16)
                row.setPadding(0, AU.dp(8), 0, AU.dp(8))
                
                icon_iv = IV(context)
                icon_applied = False
                if PI:
                    try:
                        drawable = PI.getDrawable(upd['icon_str'], AU.dp(32), Theme.getColor(Theme.key_windowBackgroundWhiteGrayIcon))
                        if drawable:
                            icon_iv.setImageDrawable(drawable)
                            icon_applied = True
                    except: pass
                
                if not icon_applied:
                    icon_iv.setImageResource(R_tg.drawable.msg_bot)
                    icon_iv.setColorFilter(jclass("android.graphics.PorterDuffColorFilter")(Theme.getColor(Theme.key_windowBackgroundWhiteGrayIcon), jclass("android.graphics.PorterDuff$Mode").SRC_IN))
                
                row.addView(icon_iv, LH.createLinear(32, 32, 0, 0, 0, 12, 0))
                
                text_l = LL(context)
                text_l.setOrientation(1)
                
                name_t = TV(context)
                name_t.setText(upd['name'])
                name_t.setTextSize(1, 16.0)
                name_t.setTypeface(AU.bold())
                name_t.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
                text_l.addView(name_t)
                
                ver_t = TV(context)
                ver_t.setText(f"{upd['old']} > {upd['new']}")
                ver_t.setTextSize(1, 13.0)
                ver_t.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader))
                text_l.addView(ver_t)
                
                row.addView(text_l, LH.createLinear(0, -2, 1.0))
                list_cont.addView(row)
            
            scroll.addView(list_cont)
            self.root.addView(scroll, LH.createLinear(-1, 0, 1.0, 0, 5, 0, 15))

            try:
                self.sticker = SIV(context, 0)
                self.sticker.setStickerPackName("UtyaDuck")
                self.sticker.setStickerNum(1) 
                self.sticker.getImageReceiver().setAutoRepeat(1)
                self.root.addView(self.sticker, LH.createLinear(110, 110, 1, 0, 0, 0, 15))
            except: pass
            
            btns = LL(context)
            btns.setOrientation(0)
            btns.setPadding(AU.dp(20), 0, AU.dp(20), 0)
            
            skip = TV(context)
            skip.setText("позже 😭")
            skip.setGravity(17)
            skip.setTextSize(1, 14.0)
            skip.setTypeface(AU.bold())
            skip.setTextColor(Theme.getColor(Theme.key_text_RedBold))
            skip.setBackground(Theme.getSelectorDrawable(False))
            skip.setPadding(AU.dp(12), AU.dp(10), AU.dp(12), AU.dp(10))
            skip.setOnClickListener(OnClickProxy(lambda v: self._handle_skip()))
            btns.addView(skip, LH.createLinear(0, -2, 1.0, 0, 0, 8, 0))
            
            upd_btn = TV(context)
            upd_btn.setText("обновить ❤️")
            upd_btn.setGravity(17)
            upd_btn.setTextSize(1, 14.0)
            upd_btn.setTypeface(AU.bold())
            upd_btn.setTextColor(Theme.getColor(Theme.key_featuredStickers_buttonText))
            upd_btn.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AU.dp(8), Theme.getColor(Theme.key_featuredStickers_addButton), 0))
            upd_btn.setPadding(AU.dp(12), AU.dp(10), AU.dp(12), AU.dp(10))
            upd_btn.setOnClickListener(OnClickProxy(lambda v: self._handle_update()))
            btns.addView(upd_btn, LH.createLinear(0, -2, 1.2))
            
            self.root.addView(btns, LH.createLinear(-1, -2))
            
            self.sheet.setCustomView(self.root)
            self.sheet.setCanDismissWithSwipe(False)
            self.sheet.setCancelable(False)
            self.sheet.setCanceledOnTouchOutside(False)
        except Exception as e:
            mlog(f"Failed to create UpdateSheet: {e}")

    def _handle_skip(self):
        global _UPDATE_SHOWN_THIS_SESSION
        _UPDATE_SHOWN_THIS_SESSION = True
        if self.sheet: self.sheet.dismiss()

    def _handle_update(self):
        if self.sheet: self.sheet.dismiss()
        self.on_update_all()

    def show(self):
        if self.sheet: self.sheet.show()

class ReMeowCore:
    @staticmethod
    def initialize(plugin_instance):
        if is_safe_mode():
            mlog("SAFE MODE ACTIVE: ReMeowCore Initialization Blocked.")
            return

        pid = getattr(plugin_instance, "__id__", "unknown")
        
        if not _CFFI_READY.is_set():
            mlog(f"[{pid}] CFFI not ready. Launching progressive async wait...")
            threading.Thread(
                target=ReMeowCore._progressive_wait, 
                args=(plugin_instance, pid),
                daemon=True,
                name=f"ReMeowWait_{pid}"
            ).start()
        else:
            ReMeowCore._finish_initialization(plugin_instance)

    @staticmethod
    def register_module(plugin_instance, name: str, version: str, status: str = "Инициализация...", ui_provider=None):
        pid = getattr(plugin_instance, "__id__", "unknown")
        loader = ReLoad.get()
        loader.registered_modules[pid] = {
            "instance": plugin_instance,
            "name": name,
            "ver": version,
            "status": status,
            "ui_cb": ui_provider
        }
        mlog(f"Module '{name}' (v{version}) registered successfully.")

    @staticmethod
    def update_module_status(plugin_instance, status: str):
        pid = getattr(plugin_instance, "__id__", "unknown")
        loader = ReLoad.get()
        if pid in loader.registered_modules:
            loader.registered_modules[pid]["status"] = status

    @staticmethod
    def _progressive_wait(plugin_instance, pid):
        timeouts = [7, 12, 17, 22]
        cffi_ok = False
        
        for t in timeouts:
            if _CFFI_READY.wait(timeout=t):
                mlog(f"[{pid}] CFFI is ready after waiting {t}s.")
                cffi_ok = True
                break
            mlog(f"[{pid}] Progressive timeout {t}s passed, CFFI still not ready...")
            
        if not cffi_ok:
            with _CFFI_REINSTALL_LOCK:
                if not _CFFI_READY.is_set():
                    mlog(f"[{pid}] Progressive timeouts exhausted. Forcing CFFI reinstall...")
                    run_on_ui_thread(lambda: BulletinHelper.show_info(f"ReMeow: Восстановление ядра для {pid}..."))
                    
                    RePip.install_wheel_direct(RePip.CFFI_URL, "cffi")
                    RePip.fix_cffi_backend()
                    try:
                        importlib.invalidate_caches()
                        import cffi
                        cffi.FFI()
                        _CFFI_READY.set()
                        mlog(f"[{pid}] CFFI forced reinstall successful!")
                    except Exception as e:
                        mlog(f"[{pid}] CFFI reinstall failed: {e}")

            post_timeouts = [8, 13]
            for t in post_timeouts:
                if _CFFI_READY.wait(timeout=t):
                    cffi_ok = True
                    break
                mlog(f"[{pid}] Post-reinstall timeout {t}s passed...")
                
        if not cffi_ok:
            mlog(f"[{pid}] FATAL: CFFI initialization completely failed. Crying sheet incoming.")
            def show_crying():
                try:
                    act = jclass("org.telegram.ui.LaunchActivity").instance
                    if not act:
                        from client_utils import get_last_fragment
                        frag = get_last_fragment()
                        if frag: act = frag.getParentActivity()
                    if act: CryingSheet(act, pid).show()
                except Exception as e:
                    mlog(f"CryingSheet show error: {e}")
            run_on_ui_thread(show_crying)
            return

        ReMeowCore._finish_initialization(plugin_instance)
        
        if hasattr(plugin_instance, "on_remeow_ready") and callable(plugin_instance.on_remeow_ready):
            try:
                plugin_instance.on_remeow_ready()
            except Exception as e:
                mlog(f"[{pid}] Error in on_remeow_ready: {e}")

    @staticmethod
    def _finish_initialization(plugin_instance):
        _, site_pkgs, _ = RePip.get_dirs()
        if site_pkgs not in sys.path:
            sys.path.insert(0, site_pkgs)
            importlib.invalidate_caches()
            
        RePip.fix_cffi_backend()

        reqs = getattr(plugin_instance, "__ReqRements__", {})
        if not reqs:
            try:
                mod = sys.modules.get(plugin_instance.__module__)
                reqs = getattr(mod, "__ReqRements__", {})
            except: pass
        if not reqs: return
        
        loader = ReLoad.get()
        pid = getattr(plugin_instance, "__id__", None)
        if not pid:
            try: pid = sys.modules[plugin_instance.__module__].__id__
            except: pid = "unknown"

        missing_modules = {}

        for name, data in reqs.items():
            p = data.split(" - ")
            url = p[0].strip()
            opt = "optional" in data.lower()
            
            path = os.path.join(loader.root, f"{name}.so")
            
            if not os.path.exists(path) or os.path.getsize(path) < 1024:
                if opt and not loader.choices.get(pid, {}).get(name, True):
                    continue
                if url:
                    missing_modules[name] = url
                elif not opt:
                    mlog(f"ReMeow: Missing required module {name} and no download URL provided.")

        if missing_modules:
            mlog(f"Missing modules detected for {pid}: {list(missing_modules.keys())}. Triggering UI download...")
            download_event = threading.Event()
            success_flag = [False]
            
            def on_finish():
                success_flag[0] = True
                download_event.set()
                
            def on_error():
                success_flag[0] = False
                download_event.set()
                
            def show_ui():
                try:
                    act = jclass("org.telegram.ui.LaunchActivity").instance
                    if not act:
                        from client_utils import get_last_fragment
                        frag = get_last_fragment()
                        if frag: act = frag.getParentActivity()
                    if act:
                        DependencyProgressSheet(act, missing_modules, on_finish, on_error).show()
                    else:
                        mlog("Failed to find Activity for DependencyProgressSheet")
                        on_error()
                except Exception as e:
                    mlog(f"Error showing sheet: {e}")
                    on_error()
                    
            run_on_ui_thread(show_ui)
            download_event.wait()
            
            if not success_flag[0]:
                mlog(f"ReMeow: Failed to download dependencies for {pid}. Please reinstall.")
                return

        for name, data in reqs.items():
            opt = "optional" in data.lower()
            path = os.path.join(loader.root, f"{name}.so")
            
            if opt and not loader.choices.get(pid, {}).get(name, True):
                continue
                
            lib = NativeLinker().load(path)
            if lib:
                loader._storage[name] = lib
            elif not opt:
                mlog(f"ReMeow: Failed to inject required module {name}")

class DependencyProgressSheet:
    def __init__(self, context, modules_to_download, on_finish, on_error=None):
        self.context = context
        self.modules = modules_to_download
        self.on_finish = on_finish
        self.on_error = on_error
        self.sheet = None
        self.has_error = False
        
        try:
            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            self.sheet = BottomSheet(context, False)
            self.sheet.fixNavigationBar()
            
            AU = jclass("org.telegram.messenger.AndroidUtilities")
            LH = jclass("org.telegram.ui.Components.LayoutHelper")
            TV = jclass("android.widget.TextView")
            LL = jclass("android.widget.LinearLayout")
            SIV = jclass("org.telegram.ui.Components.StickerImageView")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            LPV = jclass("org.telegram.ui.Components.LineProgressView")
            
            self.root = LL(context)
            self.root.setOrientation(1)
            self.root.setPadding(0, AU.dp(18), 0, AU.dp(18))
            
            try:
                self.sticker = SIV(context, 0)
                self.sticker.setStickerPackName("UtyaDuck")
                self.sticker.setStickerNum(16)
                self.sticker.getImageReceiver().setAutoRepeat(1)
                self.root.addView(self.sticker, LH.createLinear(144, 144, 1, 0, 10, 0, 0))
            except: pass
            
            self.title = TV(context)
            self.title.setText("Установка компонентов")
            self.title.setTextSize(1, 20.0)
            self.title.setTypeface(AU.bold())
            self.title.setGravity(1)
            self.title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            self.root.addView(self.title, LH.createLinear(-1, -2, 1, 40, 15, 40, 0))
            
            self.progress_view = LPV(context)
            self.progress_view.setProgressColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            self.progress_view.setBackColor(Theme.getColor(Theme.key_windowBackgroundGray))
            self.root.addView(self.progress_view, LH.createLinear(-1, 5, 1, 45, 25, 45, 0))
            
            self.description = TV(context)
            self.description.setText("Инициализация...")
            self.description.setTextSize(1, 13.0)
            self.description.setGravity(1)
            self.description.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            self.root.addView(self.description, LH.createLinear(-1, -2, 1, 35, 10, 35, 10))
            
            self.sheet.setCustomView(self.root)
            self.sheet.setCanDismissWithSwipe(False)
            self.sheet.setCancelable(False)
            self.sheet.setCanceledOnTouchOutside(False)
        except Exception as e:
            mlog(f"Failed to create DependencyProgressSheet: {e}")

    def show(self):
        if self.sheet:
            self.sheet.show()
            threading.Thread(target=self._worker, daemon=True).start()
        else:
            BulletinHelper.show_info("Скачивание модулей (в фоне)...")
            threading.Thread(target=self._worker, daemon=True).start()

    def _worker(self):
        loader = ReLoad.get()
        total_modules = len(self.modules)
        
        for idx, (name, url) in enumerate(self.modules.items()):
            if self.sheet and self.has_error: break
            
            if self.sheet:
                run_on_ui_thread(lambda n=name: self.description.setText(f"Скачивание {n}..."))
            
            path = os.path.join(loader.root, f"{name}.so")
            
            try:
                def prog_cb(down, total):
                    if self.sheet and total > 0:
                        module_progress = down / total
                        overall_progress = (idx + module_progress) / total_modules
                        run_on_ui_thread(lambda p=overall_progress: self.progress_view.setProgress(p, True))
                
                success = SafeDownloader.download(url, path, progress_cb=prog_cb)
                if not success:
                    raise Exception(f"SafeDownloader returned False for {name}")

                if self.sheet:
                    run_on_ui_thread(lambda n=name: self.description.setText(f"Успешно: {n}"))
                time.sleep(0.2)
                
            except Exception as e:
                mlog(f"Download Error in Sheet: {e}")
                self.has_error = True
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Ошибка загрузки {name}! Попробуйте снова."))
                if self.sheet:
                    run_on_ui_thread(lambda: (
                        self.description.setText("Сбой скачивания. Отмена."),
                        self.progress_view.setProgressColor(0xFFFF0000)
                    ))
                time.sleep(2)
                break
                
        time.sleep(0.5)
        run_on_ui_thread(self._finish)

    def _finish(self):
        if self.sheet: 
            try: self.sheet.dismiss()
            except: pass
        if self.has_error:
            if self.on_error: self.on_error()
        else:
            if self.on_finish: self.on_finish()
        self.sheet = None

class CoreInstallerSheet:
    def __init__(self, context, on_finish=None):
        self.context = context
        self.on_finish = on_finish
        self.sheet = None
        self.has_error = False
        
        try:
            BottomSheet = jclass("org.telegram.ui.ActionBar.BottomSheet")
            self.sheet = BottomSheet(context, False)
            self.sheet.fixNavigationBar()
            
            AU = jclass("org.telegram.messenger.AndroidUtilities")
            LH = jclass("org.telegram.ui.Components.LayoutHelper")
            TV = jclass("android.widget.TextView")
            LL = jclass("android.widget.LinearLayout")
            SIV = jclass("org.telegram.ui.Components.StickerImageView")
            Theme = jclass("org.telegram.ui.ActionBar.Theme")
            LPV = jclass("org.telegram.ui.Components.LineProgressView")
            
            self.root = LL(context)
            self.root.setOrientation(1)
            self.root.setPadding(0, AU.dp(18), 0, AU.dp(18))
            
            try:
                self.sticker = SIV(context, 0)
                self.sticker.setStickerPackName("UtyaDuck")
                self.sticker.setStickerNum(1) 
                self.sticker.getImageReceiver().setAutoRepeat(1)
                self.root.addView(self.sticker, LH.createLinear(144, 144, 1, 0, 10, 0, 0))
            except: pass
            
            self.title = TV(context)
            self.title.setText("Настройка Python")
            self.title.setTextSize(1, 20.0)
            self.title.setTypeface(AU.bold())
            self.title.setGravity(1)
            self.title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            self.root.addView(self.title, LH.createLinear(-1, -2, 1, 40, 15, 40, 0))
            
            self.progress_view = LPV(context)
            self.progress_view.setProgressColor(Theme.getColor(Theme.key_featuredStickers_addButton))
            self.progress_view.setBackColor(Theme.getColor(Theme.key_windowBackgroundGray))
            self.root.addView(self.progress_view, LH.createLinear(-1, 5, 1, 45, 25, 45, 0))
            
            self.description = TV(context)
            self.description.setText("Проверка зависимостей...")
            self.description.setTextSize(1, 13.0)
            self.description.setGravity(1)
            self.description.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            self.root.addView(self.description, LH.createLinear(-1, -2, 1, 35, 10, 35, 10))
            
            self.sheet.setCustomView(self.root)
            self.sheet.setCanDismissWithSwipe(False)
            self.sheet.setCancelable(False)
            self.sheet.setCanceledOnTouchOutside(False)
        except Exception as e:
            mlog(f"Failed to create CoreInstallerSheet: {e}")

    def show(self):
        if self.sheet:
            self.sheet.show()
            threading.Thread(target=self._worker, daemon=True).start()
        else:
            BulletinHelper.show_info("Установка ReMeow (в фоне)...")
            threading.Thread(target=self._worker, daemon=True).start()

    def _update_status(self, progress, text, is_error=False):
        def do_update():
            if self.sheet and self.progress_view and self.description:
                if is_error:
                    Theme = jclass("org.telegram.ui.ActionBar.Theme")
                    self.progress_view.setProgressColor(Theme.getColor(Theme.key_text_RedRegular))
                self.progress_view.setProgress(progress, True)
                self.description.setText(text)
        run_on_ui_thread(do_update)

    def _worker(self):
        _, site_pkgs, wheel_cache = RePip.get_dirs()
        if site_pkgs not in sys.path: sys.path.insert(0, site_pkgs)
        importlib.invalidate_caches()
        
        self._update_status(0.1, "Распаковка ядра PIP...")
        try:
            if not RePip.bootstrap():
                self.has_error = True
                self._update_status(0.1, "Ошибка загрузки PIP!", True)
                time.sleep(2)
                run_on_ui_thread(self._finish)
                return
        except Exception as e:
            mlog(f"Bootstrap failed: {e}")
            self.has_error = True

        self._update_status(0.4, "Установка pycparser...")
        try:
            RePip.ensure_pycparser()
        except Exception as e:
            mlog(f"pycparser failed: {e}")

        self._update_status(0.7, "Установка CFFI...")
        
        try:
            try:
                for f in os.listdir(wheel_cache):
                    if "cffi" in f: os.remove(os.path.join(wheel_cache, f))
            except: pass
            
            success = RePip.install_wheel_direct(RePip.CFFI_URL, "cffi")
            
            if success:
                self._update_status(0.9, "Инициализация CFFI...")
                importlib.invalidate_caches()
                RePip.fix_cffi_backend()
                try:
                    import cffi
                    cffi.FFI()
                    mlog("CFFI установлен и работает!")
                    _CFFI_READY.set()
                except Exception as ex:
                    mlog(f"CFFI import error: {ex}")
                    self.has_error = True
            else:
                mlog("CFFI installation returned False")
                self.has_error = True
                
        except Exception as e:
            mlog(f"CFFI install fatal error: {e}")
            self.has_error = True
        
        finally:
            if site_pkgs in sys.path: sys.path.remove(site_pkgs)
            _CFFI_READY.set()

        if self.has_error:
            self._update_status(1.0, "Сбой при настройке!", True)
            BulletinHelper.show_error("Ошибка настройки ядра. Попробуйте еще раз.")
            time.sleep(2)
        else:
            self._update_status(1.0, "Готово!")
            time.sleep(1)
            
        run_on_ui_thread(self._finish)

    def _finish(self):
        if self.sheet: 
            try: self.sheet.dismiss()
            except: pass
        if not self.has_error and self.on_finish: 
            self.on_finish()

class ExpandAnimListener(dynamic_proxy(jclass("android.animation.Animator$AnimatorListener"))):
    def __init__(self, wrapper):
        super().__init__()
        self.wrapper = wrapper
        self.canceled = False
        
    def onAnimationStart(self, *args):
        self.canceled = False
        self.wrapper.setVisibility(0)
        
    def onAnimationEnd(self, *args):
        if not self.canceled and self.wrapper.getLayoutParams().height == 0:
            self.wrapper.setVisibility(8)
            
    def onAnimationCancel(self, *args):
        self.canceled = True
        
    def onAnimationRepeat(self, *args): 
        pass

class ExpandAnimUpdate(dynamic_proxy(jclass("android.animation.ValueAnimator$AnimatorUpdateListener"))):
    def __init__(self, wrapper, content, arrow, target_h, state_dict):
        super().__init__()
        self.wrapper = wrapper
        self.content = content
        self.arrow = arrow
        self.target_h = target_h
        self.state = state_dict
        
    def onAnimationUpdate(self, a):
        p = float(a.getAnimatedValue())
        self.state["progress"] = p
        
        lp = self.wrapper.getLayoutParams()
        lp.height = int(self.target_h * p)
        self.wrapper.setLayoutParams(lp)
        
        alpha = max(0.0, min(1.0, (p - 0.2) / 0.8))
        self.content.setAlpha(alpha)

        scale = 0.92 + 0.08 * p
        self.content.setScaleX(scale)
        self.content.setScaleY(scale)

        offset = self.target_h * 0.15
        self.content.setTranslationY(-offset * (1.0 - p))

        self.arrow.setRotation(180.0 * p)

class OnClickProxy(dynamic_proxy(jclass("android.view.View$OnClickListener"))):
    def __init__(self, cb): super().__init__(); self.cb = cb
    def onClick(self, v): self.cb(v)

class OnLongClickProxy(dynamic_proxy(jclass("android.view.View$OnLongClickListener"))):
    def __init__(self, cb): super().__init__(); self.cb = cb
    def onLongClick(self, v): return self.cb(v)

class InstallSheetHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    
    def after_hooked_method(self, param):
        def modify_ui():
            try:
                AU, LH, TV, LL, CB, IV = jclass("org.telegram.messenger.AndroidUtilities"), jclass("org.telegram.ui.Components.LayoutHelper"), jclass("android.widget.TextView"), jclass("android.widget.LinearLayout"), jclass("org.telegram.ui.Components.CheckBox2"), jclass("android.widget.ImageView")
                Theme, ViewClass, R_tg = jclass("org.telegram.ui.ActionBar.Theme"), jclass("android.view.View"), jclass("org.telegram.messenger.R")
                PDF, PDCF = jclass("android.graphics.PorterDuff"), jclass("android.graphics.PorterDuffColorFilter")
                ColorUtils = jclass("androidx.core.graphics.ColorUtils")
                CubicBezierInterpolator = jclass("org.telegram.ui.Components.CubicBezierInterpolator")
                ValueAnimator = jclass("android.animation.ValueAnimator")
                MeasureSpec = jclass("android.view.View$MeasureSpec")
                import ast
                jarray = __import__("java").jarray
                jfloat = __import__("java").jfloat
                FrameLayout = jclass("android.widget.FrameLayout")

                sheet = param.thisObject
                plugin_id = param.args[1].plugin.getId()
                file_path = param.args[2].filePath
                reqs = {}
                try:
                    with open(file_path, 'r', encoding='utf-8') as f: data = f.read()
                    match = re.search(r'__ReqRements__\s*=\s*(\{.*?\})', data, re.DOTALL)
                    if match: reqs = ast.literal_eval(match.group(1))
                except: pass
                if not reqs: return
                
                curr = sheet.getClass()
                field = None
                while curr:
                    try: field = curr.getDeclaredField("customView"); break
                    except: curr = curr.getSuperclass()
                
                if field:
                    field.setAccessible(True)
                    sv = field.get(sheet)
                    main_layout = sv.getChildAt(0).getChildAt(0)
                    ctx = main_layout.getContext()
                    
                    idx = 1
                    source_badge = None
                    for i in range(main_layout.getChildCount()):
                        v = main_layout.getChildAt(i)
                        if isinstance(v, LL) and v.getOrientation() == 0 and v.getChildCount() > 0:
                            source_badge, idx = v, i; break
                    
                    row_cont = LL(ctx); row_cont.setOrientation(0); row_cont.setGravity(17)
                    if source_badge:
                        main_layout.removeView(source_badge)
                        row_cont.addView(source_badge, LH.createLinear(-2, -2, 0, 0, 0, 8, 0))
                    
                    accent = Theme.getColor(Theme.key_windowBackgroundWhiteBlueHeader)
                    bg_color = Theme.getColor(Theme.key_windowBackgroundWhite)
                    
                    rem_badge = LL(ctx); rem_badge.setOrientation(0); rem_badge.setGravity(17)
                    badge_bg = ColorUtils.blendARGB(bg_color, accent, 0.12)
                    pressed_color = ColorUtils.blendARGB(badge_bg, Theme.getColor(Theme.key_windowBackgroundWhiteBlackText), 0.1)
                    rem_badge.setBackground(Theme.createSimpleSelectorRoundRectDrawable(AU.dp(20), badge_bg, pressed_color))
                    rem_badge.setPadding(AU.dp(14), AU.dp(6), AU.dp(14), AU.dp(6))
                    
                    t = TV(ctx); t.setText(f"Модули: {len(reqs)}"); t.setTypeface(AU.bold()); t.setTextSize(1, 13.0); t.setTextColor(accent); rem_badge.addView(t)
                    arrow = IV(ctx); arrow.setImageResource(R_tg.drawable.msg_expand); arrow.setColorFilter(PDCF(accent, PDF.Mode.SRC_IN)); 
                    arrow.setScaleX(1.4); arrow.setScaleY(1.4); arrow.setRotation(0.0)
                    
                    rem_badge.addView(arrow, LH.createLinear(14, 14, 16, 5, 0, 0, 0))
                    row_cont.addView(rem_badge, LH.createLinear(-2, -2))
                    main_layout.addView(row_cont, idx, LH.createLinear(-1, -2, 17, 0, 18, 0, 4)) 
                    
                    anim_wrapper = LL(ctx)
                    anim_wrapper.setOrientation(1)
                    anim_wrapper.setVisibility(8) 
                    anim_wrapper.setClipChildren(True)
                    anim_wrapper.setClipToPadding(False)

                    list_cont = LL(ctx); list_cont.setOrientation(1)
                    
                    if self.plugin.get_setting("ds_cont_enabled", True):
                        c_color = jint(self.plugin.get_setting("ds_cont_color", Theme.getColor(Theme.key_windowBackgroundGray)))
                        c_rad = int(self.plugin.get_setting("ds_cont_radius", 16))
                        list_cont.setBackground(Theme.createRoundRectDrawable(AU.dp(c_rad), AU.dp(c_rad), c_color))
                        list_cont.setPadding(0, AU.dp(6), 0, AU.dp(6))

                    icon_res_name = self.plugin.get_setting("ds_icon_res", "msg_bot")
                    res_id = getattr(R_tg.drawable, icon_res_name, getattr(R_tg.drawable, "msg_bot"))
                    
                    req_cb_scale = float(self.plugin.get_setting("ds_req_cb_scale", 1.0))
                    req_cb_frame = int(self.plugin.get_setting("ds_req_cb_frame", 26))
                    req_g = int(self.plugin.get_setting("ds_req_gravity", 3))

                    for name, info in reqs.items():
                        is_need = "need" in info.lower()
                        row = LL(ctx); row.setPadding(AU.dp(18), AU.dp(10), AU.dp(18), AU.dp(10))
                        row.setBackground(Theme.getSelectorDrawable(False))
                        row.setGravity(16)
                        
                        puz = IV(ctx); puz.setImageResource(res_id); puz.setColorFilter(PDCF(Theme.getColor(Theme.key_windowBackgroundWhiteGrayIcon), PDF.Mode.SRC_IN)); 
                        row.addView(puz, LH.createLinear(22, 22, 16, 0, 0, 14, 0))
                        
                        txt_l = LL(ctx); txt_l.setOrientation(1); txt_l.setGravity(16)
                        
                        t_n = TV(ctx); t_n.setText(name); t_n.setTextSize(1, 15.0); t_n.setTypeface(AU.bold())
                        t_s = TV(ctx); t_s.setTextSize(1, 12.0)
                        
                        if is_need:
                            t_n.setGravity(req_g); t_s.setGravity(req_g)
                            t_n.setTextColor(jint(self.plugin.get_setting("ds_req_title_color", Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))))
                            t_s.setText(self.plugin.get_setting("ds_req_sub_text", "Обязательно"))
                            t_s.setTextColor(jint(self.plugin.get_setting("ds_req_sub_color", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))))
                            frame_size = req_cb_frame
                            scale = req_cb_scale
                        else:
                            opt_g = int(self.plugin.get_setting("ds_opt_gravity", 3))
                            t_n.setGravity(opt_g); t_s.setGravity(opt_g)
                            t_n.setTextColor(jint(self.plugin.get_setting("ds_opt_title_color", Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))))
                            t_s.setText(self.plugin.get_setting("ds_opt_sub_text", "Опционально"))
                            t_s.setTextColor(jint(self.plugin.get_setting("ds_opt_sub_color", Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))))
                            frame_size = int(self.plugin.get_setting("ds_opt_cb_frame", 26))
                            scale = float(self.plugin.get_setting("ds_opt_cb_scale", 1.0))

                        txt_l.addView(t_n, LH.createLinear(-1, -2))
                        txt_l.addView(t_s, LH.createLinear(-1, -2))
                        row.addView(txt_l, LH.createLinear(0, -2, 1.0, 16, 0, 0, 8, 0))
                        
                        cb = CB(ctx, 21); cb.setDrawBackgroundAsArc(10)
                        cb.setColor(Theme.key_featuredStickers_addButton, Theme.key_windowBackgroundWhite, Theme.key_featuredStickers_buttonText)
                        cb.setChecked(True if is_need else ReLoad.get().choices.get(plugin_id, {}).get(name, True), False)
                        cb.setScaleX(scale); cb.setScaleY(scale)
                        
                        cb_cont = FrameLayout(ctx)
                        cb_cont.addView(cb, LH.createLinear(-2, -2, 17))
                        
                        if not is_need: 
                            row.setOnClickListener(OnClickProxy(lambda v, n=name, c=cb: (c.setChecked(not c.isChecked(), True), ReLoad.get().save_choice(plugin_id, n, c.isChecked()))))
                        else: 
                            cb.setEnabled(False)
                            row.setAlpha(0.6) 
                        
                        row.addView(cb_cont, LH.createLinear(frame_size, frame_size, 16))
                        list_cont.addView(row)
                    
                    anim_wrapper.addView(list_cont, LH.createLinear(-1, -2, 0, 16, 12, 16, 4))
                    main_layout.addView(anim_wrapper, idx + 1, LH.createLinear(-1, -2))
                    
                    state = {"full_height": 0, "current_anim": None, "progress": 0.0, "is_expanded": False}

                    def toggle_list(v):
                        target_expanded = not state["is_expanded"]
                        state["is_expanded"] = target_expanded
                        if state["current_anim"]: state["current_anim"].cancel()
                        if state["full_height"] == 0:
                            anim_wrapper.setVisibility(0)
                            parent_w = main_layout.getWidth()
                            if parent_w == 0: parent_w = AU.displaySize.x
                            anim_wrapper.measure(MeasureSpec.makeMeasureSpec(parent_w, MeasureSpec.EXACTLY), MeasureSpec.makeMeasureSpec(0, MeasureSpec.UNSPECIFIED))
                            state["full_height"] = anim_wrapper.getMeasuredHeight()
                            clp = list_cont.getLayoutParams()
                            clp.height = list_cont.getMeasuredHeight()
                            list_cont.setLayoutParams(clp)

                        start_val = state["progress"]
                        end_val = 1.0 if target_expanded else 0.0
                        if start_val == end_val: return

                        anim = ValueAnimator.ofFloat(jarray(jfloat)([start_val, end_val]))
                        distance = abs(end_val - start_val)
                        anim.setDuration(int(350 * (0.4 + 0.6 * distance)))
                        anim.setInterpolator(CubicBezierInterpolator.EASE_OUT_QUINT)
                        anim.addUpdateListener(ExpandAnimUpdate(anim_wrapper, list_cont, arrow, state["full_height"], state))
                        anim.addListener(ExpandAnimListener(anim_wrapper))
                        state["current_anim"] = anim
                        anim.start()

                    rem_badge.setOnClickListener(OnClickProxy(toggle_list))

                install_btn = None
                try:
                    f = sheet.getClass().getDeclaredField("button")
                    f.setAccessible(True); install_btn = f.get(sheet)
                except:
                    for f in sheet.getClass().getDeclaredFields():
                        if "ButtonWithCounterView" in str(f.getType()):
                            f.setAccessible(True); install_btn = f.get(sheet); break
                if not install_btn: return

                ViewClass = jclass("android.view.View").getClass()
                li_field = ViewClass.getDeclaredField("mListenerInfo")
                li_field.setAccessible(True)
                l_info = li_field.get(install_btn)
                oc_field = l_info.getClass().getDeclaredField("mOnClickListener")
                oc_field.setAccessible(True)
                original_click = oc_field.get(l_info)

                try:
                    f_enable = sheet.getClass().getDeclaredField("enableAfterInstallation")
                    f_enable.setAccessible(True)
                except: f_enable = None

                def on_hijack(v):
                    to_download = {}
                    loader = ReLoad.get()
                    for name, info in reqs.items():
                        is_need = "need" in info.lower()
                        is_selected = loader.choices.get(plugin_id, {}).get(name, True)
                        path = os.path.join(loader.root, f"{name}.so")
                        if (is_need or is_selected) and (not os.path.exists(path) or os.path.getsize(path) < 1024):
                            to_download[name] = info.split(" - ")[0].strip()
                    
                    should_enable = False
                    if f_enable: should_enable = f_enable.getBoolean(sheet)

                    if to_download:
                        try: sheet.dismiss()
                        except: pass
                        def perform_install():
                            PC = jclass("com.exteragram.messenger.plugins.PluginsController").getInstance()
                            engine = PC.engines.get("python")
                            if not engine: engine = PC.getPluginEngine(file_path)
                            class InstallCallback(dynamic_proxy(jclass("org.telegram.messenger.Utilities$Callback"))):
                                def __init__(self): super().__init__()
                                def run(self, err):
                                    if not err and should_enable: run_on_ui_thread(lambda: PC.setPluginEnabled(plugin_id, True, None))
                            run_on_ui_thread(lambda: engine.loadPluginFromFile(file_path, None, InstallCallback()))
                        ctx = sheet.getContext()
                        DependencyProgressSheet(ctx, to_download, perform_install, lambda: None).show()
                    else:
                        original_click.onClick(install_btn)

                install_btn.setOnClickListener(OnClickProxy(on_hijack))

            except Exception as e: self.plugin.log(f"UI Hook Error: {e}")
        
        run_on_ui_thread(modify_ui, delay=150)

class Plugin2IsPluginHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def after_hooked_method(self, param):
        if param.getResult() is False:
            file_obj = param.args[0]
            if file_obj and str(file_obj.getName()).lower().endswith(".plugin2"):
                param.setResult(True)

class Plugin2InstallHook(MethodHook):
    def __init__(self, plugin): self.plugin = plugin
    def before_hooked_method(self, param):
        try:
            params = param.args[1]
            file_path = str(params.filePath)
            if file_path.lower().endswith(".plugin2"):
                cache_dir = os.path.join(jclass("org.telegram.messenger.ApplicationLoader").applicationContext.getCacheDir().getAbsolutePath(), "plugin2_extract")
                if os.path.exists(cache_dir): shutil.rmtree(cache_dir, ignore_errors=True)
                os.makedirs(cache_dir, exist_ok=True)
                with zipfile.ZipFile(file_path, 'r') as zf: zf.extractall(cache_dir)
                main_plugin_path = None
                loader_root = ReLoad.get().root
                for root, dirs, files in os.walk(cache_dir):
                    for f in files:
                        ext = f.lower()
                        f_path = os.path.join(root, f)
                        if ext.endswith(".so"):
                            dest = os.path.join(loader_root, f)
                            if os.path.exists(dest): os.remove(dest)
                            shutil.move(f_path, dest)
                        elif ext.endswith(".plugin") or ext.endswith(".py"):
                            main_plugin_path = f_path
                if main_plugin_path:
                    params.filePath = jclass("java.lang.String")(main_plugin_path)
        except Exception as e: mlog(f"Plugin2InstallHook Error: {e}")

class Plugin2ShareHook(MethodReplacement):
    def __init__(self, plugin): self.plugin = plugin
    def replace_hooked_method(self, param):
        try:
            engine = param.thisObject
            plugin_id = str(param.args[0])
            plugin_path = str(engine.getPluginPath(plugin_id))
            reqs = {}
            if os.path.exists(plugin_path):
                with open(plugin_path, 'r', encoding='utf-8') as f:
                    data = f.read()
                    match = re.search(r'__ReqRements__\s*=\s*(\{.*?\})', data, re.DOTALL)
                    if match: reqs = eval(match.group(1))
            if not reqs: return jclass("de.robv.android.xposed.XposedBridge").invokeOriginalMethod(param.method, param.thisObject, param.args)
            AppLoader = jclass("org.telegram.messenger.ApplicationLoader")
            cache_dir = str(AppLoader.applicationContext.getCacheDir().getAbsolutePath())
            share_dir = os.path.join(cache_dir, "plugin_share_temp")
            if os.path.exists(share_dir): shutil.rmtree(share_dir, ignore_errors=True)
            os.makedirs(share_dir)
            plugin_share_path = os.path.join(share_dir, f"{plugin_id}.plugin")
            shutil.copyfile(plugin_path, plugin_share_path)
            plugin2_path = os.path.join(share_dir, f"{plugin_id}.plugin2")
            loader_root = ReLoad.get().root
            with zipfile.ZipFile(plugin2_path, 'w', zipfile.ZIP_DEFLATED) as zf:
                zf.write(plugin_path, f"{plugin_id}.plugin")
                for so_name in reqs.keys():
                    so_path = os.path.join(loader_root, f"{so_name}.so")
                    if os.path.exists(so_path) and os.path.getsize(so_path) > 1024:
                        zf.write(so_path, f"{so_name}.so")
            frag = get_last_fragment()
            if not frag: return None
            activity = frag.getParentActivity()
            Intent, FileProvider, ArrayList, FileClass = jclass("android.content.Intent"), jclass("androidx.core.content.FileProvider"), jclass("java.util.ArrayList"), jclass("java.io.File")
            app_id = AppLoader.getApplicationId()
            uris = ArrayList()
            uris.add(FileProvider.getUriForFile(activity, f"{app_id}.provider", FileClass(plugin_share_path)))
            uris.add(FileProvider.getUriForFile(activity, f"{app_id}.provider", FileClass(plugin2_path)))
            intent = Intent(Intent.ACTION_SEND_MULTIPLE)
            intent.setType("*/*")
            intent.putParcelableArrayListExtra(Intent.EXTRA_STREAM, uris)
            intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
            LocaleController, R = jclass("org.telegram.messenger.LocaleController"), jclass("org.telegram.messenger.R")
            activity.startActivityForResult(Intent.createChooser(intent, LocaleController.getString(R.string.ShareFile)), 500)
            return None
        except Exception as e: mlog(f"Plugin2ShareHook Error: {e}"); return jclass("de.robv.android.xposed.XposedBridge").invokeOriginalMethod(param.method, param.thisObject, param.args)

